{
  "manifest_version": 3,

  "name": "Detab",
  "description": "Removes extra tabs opened to the same URL.",
  "version": "1.0",

  "action": {
    "default_icon": "icon.png",
    "default_title": "Remove duplicate tabs"
  },

  "background": {
    "service_worker": "detab.js"
  },

  "permissions": [ "tabs" ]
}
